# --- Public site chat + studio AI ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5-mini

# --- Studio: GitHub OAuth (https://github.com/settings/developers) ---
# Callback URL: <site>/api/studio/auth/callback (prod) and http://localhost:4321/... (dev)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Only this GitHub login can sign in to /studio.
GITHUB_ALLOWED_LOGIN=Atharva-Kanherkar
# Encrypts the session cookie. Generate: openssl rand -base64 32
SESSION_SECRET=

# --- Studio: publish target (optional; sensible defaults applied in code) ---
GITHUB_REPO_OWNER=Atharva-Kanherkar
GITHUB_REPO_NAME=portfolio-site
GITHUB_REPO_BRANCH=master

# --- Studio: Vercel Blob (drafts + uploaded/generated images) ---
# Provided automatically on Vercel when a Blob store is linked; set locally for dev.
BLOB_READ_WRITE_TOKEN=
