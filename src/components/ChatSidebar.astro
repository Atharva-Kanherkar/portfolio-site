<div class="chat-root" data-chat-root>
  <button
    type="button"
    class="chat-toggle"
    data-chat-open
    aria-controls="chat-sidebar"
    aria-expanded="false"
    aria-label="Open assistant"
  >
    Ask
  </button>

  <div class="chat-sidebar" id="chat-sidebar" data-chat-sidebar hidden>
    <div class="chat-sidebar__panel" role="dialog" aria-modal="true" aria-label="Assistant">
      <header class="chat-sidebar__header">
        <button type="button" class="chat-sidebar__close" data-chat-close aria-label="Close assistant">
          <span aria-hidden="true">×</span>
        </button>
      </header>

      <div class="chat-sidebar__messages" data-chat-messages aria-live="polite" aria-relevant="additions">
        <div class="chat-row chat-row--assistant">
          <div class="chat-message chat-message--assistant">
            <div class="chat-message__body">
              <p>
                Hi. I can help with Atharva's work, background, projects, and how to reach him. What
                would you like to know?
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="chat-sidebar__composer">
        <form class="chat-sidebar__form" data-chat-form>
          <label class="sr-only" for="chat-input">Message</label>
          <textarea
            id="chat-input"
            class="chat-sidebar__input"
            data-chat-input
            rows="3"
            placeholder="Ask about his work, writing, or background…"
            required
          ></textarea>
          <div class="chat-sidebar__actions">
            <button type="submit" class="chat-sidebar__send" data-chat-send>Send</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  import { renderChatMarkdown } from '../lib/chat-markdown';

  type ChatRole = 'user' | 'assistant';

  type ChatMessage = {
    role: ChatRole;
    content: string;
  };

  function initChat() {
    const root = document.querySelector('[data-chat-root]');
    if (!root || (root as HTMLElement).dataset.chatReady) return;
    (root as HTMLElement).dataset.chatReady = 'true';

    const sidebar = root.querySelector('[data-chat-sidebar]') as HTMLElement;
    const openButton = root.querySelector('[data-chat-open]') as HTMLButtonElement;
    const closeButton = root.querySelector('[data-chat-close]') as HTMLButtonElement;
    const form = root.querySelector('[data-chat-form]') as HTMLFormElement;
    const input = root.querySelector('[data-chat-input]') as HTMLTextAreaElement;
    const sendButton = root.querySelector('[data-chat-send]') as HTMLButtonElement;
    const messages = root.querySelector('[data-chat-messages]') as HTMLElement;

    const history: ChatMessage[] = [];
    let isOpen = false;
    let isSending = false;

    function setOpen(next: boolean) {
      isOpen = next;
      sidebar.hidden = !next;
      openButton.hidden = next;
      openButton.setAttribute('aria-expanded', String(next));
      document.body.classList.toggle('chat-open', next);

      if (next) {
        input.focus();
      } else {
        openButton.focus();
      }
    }

    function appendMessage(role: ChatRole, content: string) {
      const row = document.createElement('div');
      row.className = `chat-row chat-row--${role}`;

      const item = document.createElement('div');
      item.className = `chat-message chat-message--${role}`;

      const body = document.createElement('div');
      body.className = 'chat-message__body';

      if (role === 'assistant') {
        body.innerHTML = renderChatMarkdown(content);
      } else {
        const paragraph = document.createElement('p');
        paragraph.textContent = content;
        body.appendChild(paragraph);
      }

      item.appendChild(body);
      row.appendChild(item);
      messages.appendChild(row);
      scrollMessages();
    }

    function createThinkingIndicator() {
      const row = document.createElement('div');
      row.className = 'chat-row chat-row--assistant';

      const item = document.createElement('div');
      item.className = 'chat-message chat-message--assistant chat-message--thinking';

      const body = document.createElement('div');
      body.className = 'chat-message__body';

      const thinking = document.createElement('div');
      thinking.className = 'chat-thinking';
      thinking.setAttribute('aria-hidden', 'true');

      for (let i = 0; i < 3; i += 1) {
        const dot = document.createElement('span');
        dot.className = 'chat-thinking__dot';
        thinking.appendChild(dot);
      }

      body.appendChild(thinking);
      item.appendChild(body);
      row.appendChild(item);
      messages.appendChild(row);
      scrollMessages();

      return { row };
    }

    function createAssistantStreamMessage() {
      const row = document.createElement('div');
      row.className = 'chat-row chat-row--assistant';

      const item = document.createElement('div');
      item.className = 'chat-message chat-message--assistant chat-message--streaming';

      const body = document.createElement('div');
      body.className = 'chat-message__body';

      const stream = document.createElement('p');
      stream.className = 'chat-message__stream';
      body.appendChild(stream);

      item.appendChild(body);
      row.appendChild(item);
      messages.appendChild(row);
      scrollMessages();

      return { item, body, stream };
    }

    function scrollMessages() {
      messages.scrollTop = messages.scrollHeight;
    }

    function setLoading(loading: boolean) {
      isSending = loading;
      sendButton.disabled = loading;
      input.disabled = loading;
      sendButton.textContent = loading ? 'Sending…' : 'Send';
    }

    async function streamAssistantReply() {
      const thinking = createThinkingIndicator();
      let streamMessage: ReturnType<typeof createAssistantStreamMessage> | null = null;
      let reply = '';
      let frame: number | null = null;

      const renderStream = () => {
        if (streamMessage) {
          streamMessage.stream.textContent = reply;
          scrollMessages();
        }
        frame = null;
      };

      try {
        const response = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: history }),
        });

        if (!response.ok || !response.body) {
          throw new Error('Request failed');
        }

        const reader = response.body.getReader();
        const decoder = new TextDecoder();

        while (true) {
          const { done, value } = await reader.read();
          if (done) {
            break;
          }

          if (!streamMessage) {
            thinking.row.remove();
            streamMessage = createAssistantStreamMessage();
          }

          reply += decoder.decode(value, { stream: true });

          if (frame === null) {
            frame = requestAnimationFrame(renderStream);
          }
        }

        if (frame !== null) {
          cancelAnimationFrame(frame);
        }

        reply = reply.trim();

        if (!reply) {
          streamMessage?.item.closest('.chat-row')?.remove();
          throw new Error('Empty response');
        }

        if (!streamMessage) {
          thinking.row.remove();
          streamMessage = createAssistantStreamMessage();
          streamMessage.stream.textContent = reply;
        }

        streamMessage.item.classList.remove('chat-message--streaming');
        streamMessage.body.innerHTML = renderChatMarkdown(reply);
        history.push({ role: 'assistant', content: reply });
        scrollMessages();
      } catch (error) {
        thinking.row.remove();
        streamMessage?.item.closest('.chat-row')?.remove();
        throw error;
      }
    }

    openButton.addEventListener('click', () => setOpen(true));
    closeButton.addEventListener('click', () => setOpen(false));

    sidebar.addEventListener('click', (event) => {
      if (event.target === sidebar) {
        setOpen(false);
      }
    });

    root.querySelector('.chat-sidebar__panel')?.addEventListener('click', (event) => {
      event.stopPropagation();
    });

    sidebar.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && isOpen) {
        setOpen(false);
      }
    });

    input.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        form.requestSubmit();
      }
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const content = input.value.trim();
      if (!content || isSending) {
        return;
      }

      history.push({ role: 'user', content });
      appendMessage('user', content);
      input.value = '';
      setLoading(true);

      try {
        await streamAssistantReply();
      } catch {
        appendMessage(
          'assistant',
          'Sorry, I could not reach the assistant right now. Try again in a moment, or find Atharva on GitHub.',
        );
      } finally {
        setLoading(false);
      }
    });
  }

  document.addEventListener('astro:page-load', initChat);
</script>
