---
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import ChatSidebar from '../components/ChatSidebar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, image, type, publishedTime, modifiedTime, tags, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      tags={tags}
      jsonLd={jsonLd}
    />
    <ClientRouter />
    <Analytics mode="production" />
  </head>
  <body>
    <div class="page-shell" transition:animate="fade">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <ChatSidebar />
  </body>
</html>

<style is:global>
  @keyframes astroFadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes astroFadeOut {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  ::view-transition-old(root) {
    animation: astroFadeOut 0.2s ease-out both;
  }

  ::view-transition-new(root) {
    animation: astroFadeIn 0.25s ease-out both;
  }

  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation: none;
    }
  }

  html[data-astro-transition] .fade-in {
    animation: none;
    opacity: 1;
    transform: none;
  }
</style>
